# =============================================================================
# Home Assistant Secrets Template
# =============================================================================
# Copy to secrets.yaml and fill in actual values.
# NEVER commit secrets.yaml to Git.
#
# Vault paths for reference:
#   Proxmox creds:  vault kv get secret/services/homeassistant/proxmox
#   HA API token:   vault kv get secret/services/homeassistant
#   GitLab deploy:  vault kv get secret/services/gitlab/homeassistant
# =============================================================================

# Home Assistant core
time_zone: "America/New_York"

# Proxmox VE Integration (UI-configured — password auth, HA does NOT support
# API tokens for this integration). PVE realm = cluster-wide user DB.
proxmox_username: "homeassistant"
proxmox_password: "<from vault kv get -field=password secret/services/homeassistant/proxmox>"
proxmox_realm: "pve"

# Proxmox REST API token (for YAML REST sensors — node CPU/memory/disk).
# The UI integration uses password auth above; REST sensors use the API token
# for direct API polling. Format: PVEAPIToken=user@realm!tokenname=secret
proxmox_api_auth: "PVEAPIToken=homeassistant@pam!ha-readonly-token=<from vault kv get -field=token_secret services/homeassistant/proxmox>"

# UniFi Network Integration (UI-configured)
unifi_username: "<local admin username on UDM Pro>"
unifi_password: "<local admin password>"

# Uptime Kuma Integration (UI-configured)
uptime_kuma_api_key: "<from Uptime Kuma Settings > API Keys>"
