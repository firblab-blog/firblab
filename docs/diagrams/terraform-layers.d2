# FirbLab Terraform Layer Dependency Graph
# Shows provisioning order and inter-layer dependencies
# Source of truth: docs/CURRENT-STATE.md, terraform/layers/
# Rendered automatically by CI pipeline (ci-templates/d2-ci.yml)

direction: down

# --- Foundation layers ---
l00: "Layer 00\n00-network" {
  style.fill: "#e8f5e9"
  desc: "VLANs, Zones, Policies\nPort Profiles, Devices" {shape: text; style.font-size: 12}
}

l01: "Layer 01\n01-proxmox-base" {
  style.fill: "#e3f2fd"
  desc: "ISOs, Cloud Images\nLXC Templates" {shape: text; style.font-size: 12}
}

# --- Vault layers ---
l02i: "Layer 02\n02-vault-infra" {
  style.fill: "#fff9c4"
  desc: "vault-2 VM\n(Security VLAN 50)" {shape: text; style.font-size: 12}
}

l02c: "Layer 02\n02-vault-config" {
  style.fill: "#fff9c4"
  desc: "KV Mounts, Policies\nAppRole, Auth Backends" {shape: text; style.font-size: 12}
}

# --- Core infra layers ---
l03i: "Layer 03\n03-core-infra" {
  style.fill: "#f3e5f5"
  desc: "GitLab VM\nRunner LXC" {shape: text; style.font-size: 12}
}

l03g: "Layer 03\n03-gitlab-config" {
  style.fill: "#f3e5f5"
  desc: "Groups, Projects\nLabels, CI/CD Vars\nDeploy Tokens" {shape: text; style.font-size: 12}
}

# --- Workload layers ---
l04: "Layer 04\n04-rke2-cluster" {
  style.fill: "#fff3e0"
  desc: "3 Server + 3 Agent VMs\n(Services VLAN 20)" {shape: text; style.font-size: 12}
}

l05: "Layer 05\n05-standalone-services" {
  style.fill: "#fce4ec"
  desc: "Ghost, FoundryVTT, Roundcube\nMealie, WireGuard, NetBox" {shape: text; style.font-size: 12}
}

l06: "Layer 06\n06-hetzner" {
  style.fill: "#eceff1"
  desc: "Hetzner VPS\nCloudflare DNS, S3" {shape: text; style.font-size: 12}
}

# --- Dependencies (build order) ---
l00 -> l01: "network ready"
l01 -> l02i: "templates available"
l01 -> l03i: "templates available"
l01 -> l04: "templates available"
l01 -> l05: "templates available"
l02i -> l02c: "Vault running"
l02c -> l03i: "secrets in Vault"
l02c -> l04: "secrets in Vault"
l02c -> l05: "secrets in Vault"
l02c -> l06: "secrets in Vault"
l03i -> l03g: "GitLab running"

# --- Shared modules ---
modules: "Shared Modules" {
  style.fill: "#fafafa"
  style.stroke-dash: 3
  proxmox-vm: proxmox-vm {shape: hexagon}
  proxmox-lxc: proxmox-lxc {shape: hexagon}
  proxmox-rke2: proxmox-rke2-cluster {shape: hexagon}
  vault-cluster: vault-cluster {shape: hexagon}
  hetzner-server: hetzner-server {shape: hexagon}
  cloudflare-dns: cloudflare-dns {shape: hexagon}
}

modules.proxmox-vm -> l02i {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.proxmox-vm -> l03i {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.proxmox-vm -> l05 {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.proxmox-lxc -> l03i {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.proxmox-lxc -> l05 {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.proxmox-rke2 -> l04 {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.vault-cluster -> l02i {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.hetzner-server -> l06 {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
modules.cloudflare-dns -> l06 {style.stroke-dash: 3; style.stroke: "#9e9e9e"}
