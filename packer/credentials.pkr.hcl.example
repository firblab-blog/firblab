# =============================================================================
# Packer Credentials (Bootstrap Only)
# =============================================================================
# Only needed when Vault is not available (initial bootstrap before Vault
# exists). Once Vault is running, use ./scripts/packer-build.sh instead,
# which reads credentials from Vault automatically.
#
# Bootstrap usage:
#   cp credentials.pkr.hcl.example credentials.pkr.hcl
#   # Edit credentials.pkr.hcl with your actual values
#   packer build -var-file=credentials.pkr.hcl ubuntu-24.04-base.pkr.hcl
#
# NEVER commit credentials.pkr.hcl to version control.
# =============================================================================

proxmox_url          = "https://10.0.10.2:8006/api2/json"
proxmox_token_id     = "packer@pam!packer-token"
proxmox_token_secret = "00000000-0000-0000-0000-000000000000"
proxmox_node         = "lab-02"
