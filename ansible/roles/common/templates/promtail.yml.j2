---
# =============================================================================
# Promtail configuration — generated by Ansible
# =============================================================================
# Ships system logs to Loki on the K3s monitoring cluster.
# Labels: host, group, job, filename — enables filtering in Grafana.

server:
  http_listen_port: 9080
  grpc_listen_port: 0
  log_level: warn

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ monitoring_loki_push_url }}
    tenant_id: ""
    batchwait: 1s
    batchsize: 1048576  # 1 MiB
    timeout: 10s
    backoff_config:
      min_period: 500ms
      max_period: 5m
      max_retries: 10

scrape_configs:
  # ---------------------------------------------------------------------------
  # System logs (OS-family aware)
  # ---------------------------------------------------------------------------
  - job_name: system-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: system-logs
          host: {{ inventory_hostname }}
          group: {{ monitoring_host_group | default('ungrouped') }}
{% if ansible_os_family == 'RedHat' %}
          __path__: /var/log/messages
{% else %}
          __path__: /var/log/syslog
{% endif %}
    relabel_configs:
      - source_labels: [__path__]
        target_label: filename

  - job_name: auth-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: auth-logs
          host: {{ inventory_hostname }}
          group: {{ monitoring_host_group | default('ungrouped') }}
{% if ansible_os_family == 'RedHat' %}
          __path__: /var/log/secure
{% else %}
          __path__: /var/log/auth.log
{% endif %}
    pipeline_stages:
      - multiline:
          firstline: '^\w{3}\s+\d{1,2}\s+\d{2}:\d{2}:\d{2}'
          max_wait_time: 3s
    relabel_configs:
      - source_labels: [__path__]
        target_label: filename

  - job_name: kern-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: kern-logs
          host: {{ inventory_hostname }}
          group: {{ monitoring_host_group | default('ungrouped') }}
          __path__: /var/log/kern.log
    relabel_configs:
      - source_labels: [__path__]
        target_label: filename

{% if monitoring_promtail_docker_logs | default(false) | bool %}
  # ---------------------------------------------------------------------------
  # Docker container stdout/stderr logs
  # ---------------------------------------------------------------------------
  - job_name: docker-containers
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker-logs
          host: {{ inventory_hostname }}
          group: {{ monitoring_host_group | default('ungrouped') }}
          __path__: /var/lib/docker/containers/*/*.log
    pipeline_stages:
      - json:
          expressions:
            stream: stream
            msg: log
      - labels:
          stream:
      - output:
          source: msg
    relabel_configs:
      - source_labels: [__path__]
        regex: /var/lib/docker/containers/(.{12}).+/.+
        target_label: container_id
      - source_labels: [__path__]
        target_label: filename
{% endif %}
