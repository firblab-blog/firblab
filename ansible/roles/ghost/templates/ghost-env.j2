# =============================================================================
# Ghost Environment Variables
# =============================================================================
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

# Site configuration
url={{ ghost_site_url }}
NODE_ENV=production

# Database configuration
database__client=mysql
database__connection__host=mysql
database__connection__port=3306
database__connection__user={{ ghost_db_user | default('ghost') }}
database__connection__password={{ ghost_db_password }}
database__connection__database={{ ghost_db_name | default('ghost') }}

# Security — disable staff device verification (requires working email)
# Without a configured mail transport, Ghost blocks admin login from any
# new browser/domain because it can't send the verification code.
security__staffDeviceVerification=false

# Logging
logging__level={{ ghost_log_level | default('info') }}
logging__transports=["stdout"]

{% if ghost_mail_transport is defined %}
# Mail configuration
mail__transport={{ ghost_mail_transport }}
mail__from={{ ghost_mail_from | default('noreply@' + ansible_fqdn) }}
{% if ghost_mail_host is defined %}
mail__options__host={{ ghost_mail_host }}
mail__options__port={{ ghost_mail_port | default('587') }}
mail__options__auth__user={{ ghost_mail_user | default('') }}
mail__options__auth__pass={{ ghost_mail_password | default('') }}
{% endif %}
{% endif %}
