// =============================================================================
// Grafana Alloy Configuration — Honeypot Log Shipping
// =============================================================================
// Managed by Ansible — DO NOT EDIT MANUALLY
// Replaces Promtail (EOL March 2026). Ships OpenCanary + Cowrie + Dionaea
// JSON logs to Loki on the RKE2 cluster via WireGuard tunnel.
// Alloy buffers locally via WAL (~4h TTL) and retries if Loki is unreachable.
// Data from outages longer than the WAL TTL will be lost.
// =============================================================================

// --- Loki destination ---
loki.write "default" {
  endpoint {
    url = "{{ honeypot_alloy_loki_url }}/loki/api/v1/push"

    retry_on_http_429 = true
  }
  external_labels = {
    host        = "{{ honeypot_alloy_host_label }}",
    environment = "production",
  }
}

// --- OpenCanary logs ---
local.file_match "opencanary" {
  path_targets = [{
    __path__ = "/var/log/opencanary/opencanary.json",
    job      = "opencanary",
    service  = "honeypot",
  }]
}

loki.source.file "opencanary" {
  targets       = local.file_match.opencanary.targets
  forward_to    = [loki.write.default.receiver]
  tail_from_end = false  // read from beginning on first tailing (no position file)
}

// --- Cowrie logs ---
local.file_match "cowrie" {
  path_targets = [{
    __path__ = "/var/log/cowrie/cowrie.json",
    job      = "cowrie",
    service  = "honeypot",
  }]
}

loki.source.file "cowrie" {
  targets       = local.file_match.cowrie.targets
  forward_to    = [loki.write.default.receiver]
  tail_from_end = false  // read from beginning on first tailing (no position file)
}

{% if honeypot_dionaea_enabled | default(true) %}
// --- Dionaea logs ---
local.file_match "dionaea" {
  path_targets = [{
    __path__ = "/var/log/dionaea/dionaea.json",
    job      = "dionaea",
    service  = "honeypot",
  }]
}

loki.source.file "dionaea" {
  targets       = local.file_match.dionaea.targets
  forward_to    = [loki.write.default.receiver]
  tail_from_end = false  // read from beginning on first tailing (no position file)
}
{% endif %}
