# =============================================================================
# WAR Platform — Docker Compose
# Generated by Ansible. Do not edit manually.
# WAR owns the runtime contract; this adapter supplies images and storage overlays.
# =============================================================================

networks:
  war-network:
    driver: bridge

volumes:
  war-postgres-data:
  war-recall-data:
  war-guardrail-data:
  war-service-data:
  war-claude-projects:
  war-codex:
  war-workspace:

services:
  postgres:
    image: {{ war_postgres_image }}
    container_name: war-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${WAR_DB_USER}
      POSTGRES_PASSWORD: ${WAR_DB_PASSWORD}
      POSTGRES_DB: ${WAR_DB_NAME}
    volumes:
      - war-postgres-data:/var/lib/postgresql/data
    networks:
      - war-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${WAR_DB_USER} -d ${WAR_DB_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 10

  recall-service:
    image: {{ war_recall_service_image }}
    container_name: war-recall-service
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      CC_RECALL_DATABASE_URL: postgresql://${WAR_DB_USER}:${WAR_DB_PASSWORD}@postgres:5432/${WAR_DB_NAME}
      CC_RECALL_DATA_DIR: /var/lib/recall-service
      CC_RECALL_PROJECTS_DIR: /data/claude-projects
      CC_RECALL_CODEX_DIR: /data/codex
      CC_RECALL_HTTP_HOST: 0.0.0.0
      CC_RECALL_HTTP_PORT: ${RECALL_HTTP_PORT}
      CC_RECALL_AUTO_EMBEDDINGS: "false"
      CC_RECALL_USER: default
      RECALL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
    volumes:
      - war-recall-data:/var/lib/recall-service
      - war-claude-projects:/data/claude-projects
      - war-codex:/data/codex
    networks:
      - war-network
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:${RECALL_HTTP_PORT}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  guardrail-service:
    image: {{ war_guardrail_service_image }}
    container_name: war-guardrail-service
    restart: unless-stopped
    environment:
      GUARDRAIL_DATA_DIR: /var/lib/guardrail
      GUARDRAIL_HTTP_HOST: 0.0.0.0
      GUARDRAIL_HTTP_PORT: ${GUARDRAIL_HTTP_PORT}
      GUARDRAIL_SYNC_CLAUDE: "false"
      GUARDRAIL_SYNC_CODEX: "false"
      GUARDRAIL_PROJECTS_ROOT: /workspace/projects
      GUARDRAIL_PROJECTS_ROOT_ALIASES: firblab
      GUARDRAIL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
    volumes:
      - war-guardrail-data:/var/lib/guardrail
      - war-workspace:/workspace/projects:ro
    networks:
      - war-network
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:${GUARDRAIL_HTTP_PORT}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  war-service:
    image: {{ war_service_image }}
    container_name: war-war-service
    restart: unless-stopped
    depends_on:
      recall-service:
        condition: service_healthy
      guardrail-service:
        condition: service_healthy
    environment:
      WAR_HTTP_HOST: 0.0.0.0
      WAR_HTTP_PORT: ${WAR_HTTP_PORT}
      WAR_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      RECALL_API_BASE_URL: http://recall-service:${RECALL_HTTP_PORT}
      RECALL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      GUARDRAIL_API_BASE_URL: http://guardrail-service:${GUARDRAIL_HTTP_PORT}
      GUARDRAIL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      WAR_SERVICE_DATA_DIR: /var/lib/war-service
    volumes:
      - war-service-data:/var/lib/war-service
    networks:
      - war-network
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:${WAR_HTTP_PORT}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  dashboard:
    image: {{ war_dashboard_image }}
    container_name: war-dashboard
    restart: unless-stopped
    ports:
      - "${WAR_BIND_HOST}:${WAR_DASHBOARD_PORT}:3000"
    environment:
      DATABASE_URL: postgresql://${WAR_DB_USER}:${WAR_DB_PASSWORD}@postgres:5432/${WAR_DB_NAME}
      NEXTAUTH_SECRET: ${NEXTAUTH_SECRET}
      NEXTAUTH_URL: ${NEXTAUTH_URL}
      RECALL_API_BASE_URL: http://recall-service:${RECALL_HTTP_PORT}
      RECALL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      GUARDRAIL_API_BASE_URL: http://guardrail-service:${GUARDRAIL_HTTP_PORT}
      GUARDRAIL_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      WAR_API_BASE_URL: http://war-service:${WAR_HTTP_PORT}
      WAR_API_TOKEN: ${WAR_SERVICE_SHARED_TOKEN}
      CC_RECALL_PROJECTS_DIR: /data/claude-projects
      CC_RECALL_CODEX_DIR: /data/codex
    volumes:
      - war-claude-projects:/data/claude-projects
      - war-codex:/data/codex
    networks:
      - war-network
    depends_on:
      postgres:
        condition: service_healthy
      recall-service:
        condition: service_healthy
      guardrail-service:
        condition: service_healthy
      war-service:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:3000/login').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10
