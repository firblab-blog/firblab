# =============================================================================
# WAR Platform — Docker Compose
# Generated by Ansible. Do not edit manually.
# =============================================================================

networks:
  war-network:
    driver: bridge

volumes:
  war-postgres-data:
  war-recall-data:
  war-guardrail-data:
  war-service-data:
  # Named volumes replace local bind mounts (claude-projects, codex, workspace)
  # used in local dev. In homelab these start empty; recall-service manages
  # indexing of any projects synced into war-claude-projects by the operator.
  war-claude-projects:
  war-codex:
  war-workspace:

services:

  # ---------------------------------------------------------------------------
  # PostgreSQL — shared database for WAR services
  # ---------------------------------------------------------------------------
  postgres:
    image: {{ war_postgres_image }}
    container_name: war-postgres
    restart: unless-stopped
    env_file: config/war.env
    volumes:
      - war-postgres-data:/var/lib/postgresql/data
    networks:
      - war-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ war_db_user }} -d {{ war_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 10

  # ---------------------------------------------------------------------------
  # recall-service — memory and context management backend
  # ---------------------------------------------------------------------------
  recall-service:
    image: {{ war_recall_service_image }}
    container_name: war-recall-service
    restart: unless-stopped
    env_file: config/war.env
    volumes:
      - war-recall-data:/var/lib/recall-service
      - war-claude-projects:/data/claude-projects
      - war-codex:/data/codex
    networks:
      - war-network
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:{{ war_recall_service_port }}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  # ---------------------------------------------------------------------------
  # guardrail-service — trusted guidance and constraints backend
  # ---------------------------------------------------------------------------
  guardrail-service:
    image: {{ war_guardrail_service_image }}
    container_name: war-guardrail-service
    restart: unless-stopped
    env_file: config/war.env
    volumes:
      - war-guardrail-data:/var/lib/guardrail
      - war-workspace:/workspace/projects:ro
    networks:
      - war-network
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:{{ war_guardrail_service_port }}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  # ---------------------------------------------------------------------------
  # war-service — adjudication and synthesis orchestration backend
  # ---------------------------------------------------------------------------
  war-service:
    image: {{ war_service_image }}
    container_name: war-war-service
    restart: unless-stopped
    env_file: config/war.env
    volumes:
      - war-service-data:/var/lib/war-service
    networks:
      - war-network
    depends_on:
      recall-service:
        condition: service_healthy
      guardrail-service:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:{{ war_war_service_port }}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10

  # ---------------------------------------------------------------------------
  # dashboard — Next.js frontend (public-facing via Traefik)
  # ---------------------------------------------------------------------------
  dashboard:
    image: {{ war_dashboard_image }}
    container_name: war-dashboard
    restart: unless-stopped
    env_file: config/war.env
    ports:
      - "127.0.0.1:{{ war_dashboard_port }}:3000"
    volumes:
      - war-claude-projects:/data/claude-projects
      - war-codex:/data/codex
    networks:
      - war-network
    depends_on:
      postgres:
        condition: service_healthy
      recall-service:
        condition: service_healthy
      guardrail-service:
        condition: service_healthy
      war-service:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:3000/login').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 10
