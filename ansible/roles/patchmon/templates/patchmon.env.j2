# =============================================================================
# PatchMon Environment Configuration — FirbLab
# =============================================================================
# Managed by Ansible — do not edit manually.
# Secrets are sourced from Vault (seeded by Terraform Layer 02-vault-config).
# =============================================================================

# --- Required secrets ---
POSTGRES_PASSWORD={{ patchmon_db_password }}
REDIS_PASSWORD={{ patchmon_redis_password }}
JWT_SECRET={{ patchmon_jwt_secret }}

# --- Server access ---
SERVER_PROTOCOL={{ patchmon_server_protocol }}
SERVER_HOST={{ ansible_host }}
SERVER_PORT={{ patchmon_server_port }}
CORS_ORIGIN={{ patchmon_server_protocol }}://{{ ansible_host }}:{{ patchmon_server_port }}

# --- Environment ---
NODE_ENV=production
LOG_LEVEL={{ patchmon_log_level }}
TZ={{ patchmon_timezone }}

# --- Network ---
TRUST_PROXY=1

{% if patchmon_oidc_enabled | default(false) | bool %}
# --- OIDC Single Sign-On (Authentik) ---
# Credentials from Vault (secret/services/patchmon/oidc), seeded by Layer 07.
OIDC_ENABLED=true
OIDC_ISSUER_URL={{ patchmon_oidc_issuer_url }}
OIDC_CLIENT_ID={{ patchmon_oidc_client_id }}
OIDC_CLIENT_SECRET={{ patchmon_oidc_client_secret }}
OIDC_REDIRECT_URI={{ patchmon_oidc_redirect_uri }}
OIDC_SCOPES={{ patchmon_oidc_scopes }}
OIDC_AUTO_CREATE_USERS={{ patchmon_oidc_auto_create_users | lower }}
OIDC_DEFAULT_ROLE={{ patchmon_oidc_default_role }}
OIDC_DISABLE_LOCAL_AUTH={{ patchmon_oidc_disable_local_auth | lower }}
OIDC_BUTTON_TEXT={{ patchmon_oidc_button_text }}
OIDC_ADMIN_GROUP={{ patchmon_oidc_admin_group }}
OIDC_USER_GROUP={{ patchmon_oidc_user_group }}
OIDC_SYNC_ROLES={{ patchmon_oidc_sync_roles | lower }}
{% endif %}
