# =============================================================================
# upsd User Authentication — /etc/nut/upsd.users
# =============================================================================
# Managed by Ansible — DO NOT EDIT MANUALLY
# Host: {{ inventory_hostname }}
#
# Passwords sourced from Vault: secret/services/nut
# =============================================================================

# Monitor user — for upsmon on this host and remote NUT clients (secondaries).
# NUT 2.8+ uses "primary" instead of legacy "master".
[{{ nut_monitor_user }}]
    password = {{ nut_monitor_password }}
    upsmon primary

# Admin user — full control (SET commands, instant commands)
[{{ nut_admin_user }}]
    password = {{ nut_admin_password }}
    actions = SET
    instcmds = ALL
    upsmon primary
