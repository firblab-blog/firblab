# =============================================================================
# SonarQube CE — Environment Configuration
# =============================================================================
# Managed by Ansible — do not edit manually.
# =============================================================================

# --- Database ---
SONAR_JDBC_URL=jdbc:postgresql://db:5432/{{ sonarqube_db_name }}
SONAR_JDBC_USERNAME={{ sonarqube_db_user }}
SONAR_JDBC_PASSWORD={{ sonarqube_db_password }}

# --- JVM Tuning ---
SONAR_WEB_JAVAOPTS=-Xms{{ sonarqube_jvm_xms }} -Xmx{{ sonarqube_jvm_xmx }}
SONAR_CE_JAVAOPTS=-Xms{{ sonarqube_ce_jvm_xms }} -Xmx{{ sonarqube_ce_jvm_xmx }}

# --- Web Context ---
SONAR_WEB_CONTEXT=/
SONAR_WEB_PORT=9000

# --- Instance ---
sonar.core.serverBaseURL={{ sonarqube_base_url }}

# --- Security ---
sonar.forceAuthentication=true

# --- GitLab OAuth ---
sonar.auth.gitlab.enabled=true
sonar.auth.gitlab.url={{ sonarqube_gitlab_url }}
sonar.auth.gitlab.applicationId={{ sonarqube_gitlab_oauth_client_id }}
sonar.auth.gitlab.secret={{ sonarqube_gitlab_oauth_client_secret }}
sonar.auth.gitlab.allowUsersToSignUp=false
sonar.auth.gitlab.syncUserGroups=true

# --- GitLab ALM Integration ---
sonar.alm.gitlab.token={{ sonarqube_gitlab_alm_token }}

# --- Timezone ---
TZ={{ sonarqube_timezone }}
