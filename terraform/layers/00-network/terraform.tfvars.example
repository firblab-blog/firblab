# UniFi gw-01 connection
unifi_username = "admin"
unifi_password = "CHANGE_ME"
unifi_api_url  = "https://10.0.4.1"

# DNS servers per VLAN (customize as needed)
management_dns_servers = ["1.1.1.1", "8.8.8.8"]
services_dns_servers   = ["1.1.1.1", "8.8.8.8"]
dmz_dns_servers        = ["1.1.1.1", "8.8.8.8"]
security_dns_servers   = ["1.1.1.1", "8.8.8.8"]

# Switch MAC addresses (required for device management)
# Find in UniFi controller: Devices > [switch] > General info panel
switch_closet_mac  = "REPLACE_ME"  # switch-01 (USW Flex 2.5G 5-port, closet)
switch_minilab_mac = "REPLACE_ME"  # switch-02 (USW Flex 2.5G 8, minilab)
switch_rackmate_mac = "REPLACE_ME" # switch-03 (USW Flex 2.5G 5-port, rackmate)
